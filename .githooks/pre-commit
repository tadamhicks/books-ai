#!/usr/bin/env bash
set -euo pipefail

fail() {
  echo "ERROR: $*" >&2
  exit 1
}

# Block committing common secret files by name/pattern.
# Note: allow committing k8s/secrets.example.yaml (placeholders only).
blocked_paths_regex='(^|/)(\.env($|\.))|(^|/)\.aws/|(\.pem$)|(\.key$)|(\.p12$)|(\.pfx$)|(^|/)id_rsa$|(^|/)id_ed25519$|(^|/)k8s/secrets(?!\.example)\..*\.ya?ml$'

staged_files="$(git diff --cached --name-only)"
if [[ -z "${staged_files}" ]]; then
  exit 0
fi

while IFS= read -r f; do
  [[ -z "${f}" ]] && continue
  if [[ "${f}" =~ ${blocked_paths_regex} ]]; then
    fail "Refusing to commit '${f}'. Put secrets in .env/.aws/ or k8s/secrets*.yaml locally (gitignored) and commit only example files."
  fi
done <<< "${staged_files}"

# Scan staged diff content for common secret patterns.
# Note: we deliberately scan the diff (not working tree) so it matches what will be committed.
diff="$(git diff --cached -U0)"

# High-confidence patterns:
patterns=(
  'AKIA[0-9A-Z]{16}'                       # AWS access key id
  'ASIA[0-9A-Z]{16}'                       # AWS session access key id
  'ABSK[0-9A-Za-z+/=]{20,}'                # Bedrock API key (example format seen in docs/spec)
  '-----BEGIN (RSA|OPENSSH|EC|DSA) PRIVATE KEY-----'
  'xox[baprs]-[0-9A-Za-z-]{10,}'           # Slack tokens
  'ghp_[0-9A-Za-z]{36,}'                   # GitHub classic PAT
  'github_pat_[0-9A-Za-z_]{50,}'           # GitHub fine-grained PAT
  'Authorization:[[:space:]]*Bearer[[:space:]]+[0-9A-Za-z._~+/=-]{16,}'
  'AWS_SECRET_ACCESS_KEY[[:space:]]*[:=][[:space:]]*[0-9A-Za-z/+=]{20,}'
  'AWS_BEARER_TOKEN_BEDROCK[[:space:]]*[:=][[:space:]]*[0-9A-Za-z._~+/=-]{16,}'
)

for p in "${patterns[@]}"; do
  if echo "${diff}" | LC_ALL=C grep -nE "${p}" >/dev/null 2>&1; then
    echo "${diff}" | LC_ALL=C grep -nE "${p}" | head -n 20 >&2
    fail "Potential secret detected in staged changes (pattern: ${p}). Remove/redact it and try again."
  fi
done

# Lightweight guard: detect obvious secret-y YAML key/value pairs with non-placeholder values.
# Only run this check for staged YAML files to avoid false positives from code/comments.
# Allowlist placeholders that are safe to commit.
allowlist_regex='^(REPLACE|CHANGEME|CHANGE_ME|REDACTED|""|'"'"''"'"'|<REPLACE>|<CHANGEME>|null|NULL)$'
while IFS= read -r f; do
  [[ -z "${f}" ]] && continue
  case "${f}" in
    *.yml|*.yaml)
      file_diff="$(git diff --cached -U0 -- "${f}")"
      if echo "${file_diff}" | grep -E '^\+.*(password|secret|token|api[_-]?key|access[_-]?key)[^:]*:[[:space:]]*[^#[:space:]]+' -i >/dev/null 2>&1; then
        while IFS= read -r line; do
          # Extract the scalar value after ":" for simple YAML key: value lines.
          val="$(echo "${line}" | sed -E 's/^(\+.*):[[:space:]]*([^#[:space:]]+).*/\2/' | tr -d '"')"
          if [[ -n "${val}" ]] && ! [[ "${val}" =~ ${allowlist_regex} ]]; then
            echo "${line}" >&2
            fail "Potential secret-like YAML value detected. Use placeholders (e.g. REPLACE) in committed examples; keep real secrets out of git."
          fi
        done < <(echo "${file_diff}" | grep -E '^\+.*(password|secret|token|api[_-]?key|access[_-]?key)[^:]*:[[:space:]]*[^#[:space:]]+' -i | head -n 50)
      fi
      ;;
  esac
done <<< "${staged_files}"

exit 0


